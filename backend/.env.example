# Supabase Postgres connection string (Project Settings -> Database -> Connection
# string -> Session pooler or Transaction pooler tab - the direct connection host
# requires IPv6 and often fails to resolve on IPv4-only networks).
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Outbound email (Gmail SMTP with an App Password - free, no third-party signup).
# Generate one at https://myaccount.google.com/apppasswords (requires 2-Step Verification
# enabled on the Gmail account). Leave both blank to skip email delivery entirely -
# credentials still show up in the admin API response either way.
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_APP_PASSWORD=your_16_character_app_password

NEO4J_URI=neo4j+s://xxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Langfuse tracing for AI calls (free tier at https://cloud.langfuse.com - Settings
# > API Keys after creating a project). Leave both blank to disable tracing entirely.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# AWS S3 file storage (optional - takes priority over Supabase/local when set).
# Bucket should be PRIVATE (block all public access) - files are only ever read
# back through this backend's authenticated API, never a public URL.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=conceptintel-files
UPLOAD_DIR=uploads
